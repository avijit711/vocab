{
    "version": 2,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "routes": [
        {
            "src": "/build/assets/(.*)",
            "dest": "/public/build/assets/$1"
        },
        {
            "src": "/icons/(.*)",
            "dest": "/public/icons/$1"
        },
        {
            "src": "/(manifest.json|serviceworker.js|offline.html)",
            "dest": "/public/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_URL": "https://vocab-ashy-sigma.vercel.app",
        "APP_NAME": "VocabMaster Pro",
        "LOG_CHANNEL": "stderr",
        "LOG_LEVEL": "error",
        "CACHE_DRIVER": "array",
        "SESSION_DRIVER": "cookie",
        "QUEUE_CONNECTION": "sync",
        "DB_CONNECTION": "pgsql",
        "LARAVEL_STORAGE_PATH": "/tmp/storage",
        "APP_KEY": "base64:eHMONxP+ZuJdpP0qJBGVeYZgyrK7danHZx16tzwmsDs="
    }
}
